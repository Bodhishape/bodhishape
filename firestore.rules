rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Help helper functions for authentication and roles
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             role in getUserData().roles;
    }

    // Default fallback to deny access to other paths
    match /{document=**} {
      allow read, write: if false;
    }

    // Users Collection rules
    match /users/{userId} {
      // Anyone logged in can read a profile, but only the owner or an admin can write
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || hasRole('admin'));
    }

    // Activities Collection rules
    match /activities/{activityId} {
      // Anyone logged in can read, but only owner or admin can write
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || hasRole('admin') || (resource != null && resource.data.userId == request.auth.uid));
    }

    // Posts Collection rules
    match /posts/{postId} {
      // Feed is public read to members, but only authors or admins can write/delete
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || hasRole('admin') || (resource != null && resource.data.userId == request.auth.uid));
    }

    // Goals Collection rules
    match /goals/{goalId} {
      // Only owner or admin can read/write
      allow read, write: if isAuthenticated() && (hasRole('admin') || (resource == null && request.resource.data.userId == request.auth.uid) || (resource != null && resource.data.userId == request.auth.uid));
    }

    // Communities Collection rules
    match /communities/{communityId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || hasRole('admin') || (resource != null && resource.data.userId == request.auth.uid));
    }

    // Chat messages Collection rules
    match /chats/{chatId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        hasRole('admin') ||
        (
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.messageContent == resource.data.messageContent &&
          request.resource.data.communityId == resource.data.communityId
        )
      );
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasRole('admin'));
    }

    // Kofu Collection rules
    match /kofu/{kofuId} {
      allow read, write: if isAuthenticated() && (hasRole('admin') || (resource == null && request.resource.data.userId == request.auth.uid) || (resource != null && resource.data.userId == request.auth.uid));
    }

    // BS Subscription Collection rules
    match /bs_subscription/{bsId} {
      allow read, write: if isAuthenticated() && (hasRole('admin') || (resource == null && request.resource.data.userId == request.auth.uid) || (resource != null && resource.data.userId == request.auth.uid));
    }

    // Stories Collection rules
    match /stories/{storyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        hasRole('admin') ||
        (
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.title == resource.data.title &&
          request.resource.data.content == resource.data.content &&
          request.resource.data.category == resource.data.category
        )
      );
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || hasRole('admin'));
    }

    // Active Practitioners Collection rules
    match /active_practitioners/{practitionerId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == practitionerId || hasRole('admin'));
    }

    // Persistent Media Collection rules
    match /persistent_media/{mediaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if hasRole('admin');
    }

    // Reminders Collection rules
    match /reminders/{reminderId} {
      allow read, write: if isAuthenticated() && (hasRole('admin') || (resource == null && request.resource.data.userId == request.auth.uid) || (resource != null && resource.data.userId == request.auth.uid));
    }
  }
}
